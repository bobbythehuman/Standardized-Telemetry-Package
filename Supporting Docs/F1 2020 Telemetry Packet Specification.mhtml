ee appendix</span>
    <span class=3D"kt">uint8_t</span>    <span class=3D"n">m_raceNumber</sp=
an><span class=3D"p">;</span>             <span class=3D"c1">// Race number=
 of the car</span>
    <span class=3D"kt">uint8_t</span>    <span class=3D"n">m_nationality</s=
pan><span class=3D"p">;</span>            <span class=3D"c1">// Nationality=
 of the driver</span>
    <span class=3D"kt">char</span>       <span class=3D"n">m_name</span><sp=
an class=3D"p">[</span><span class=3D"mi">48</span><span class=3D"p">];</sp=
